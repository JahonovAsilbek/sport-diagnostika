# Sample environment for the backend. Copy to `backend/.env` and adjust.
# `.env` is git-ignored; this template is committed.

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL, psycopg v3)
DATABASE_URL=postgres://sport:sport@localhost:5432/sport
# docker compose `db` service credentials (keep in sync with DATABASE_URL)
POSTGRES_DB=sport
POSTGRES_USER=sport
POSTGRES_PASSWORD=sport

# Redis — cache + Celery broker/result backend
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS — SPA dev origin (Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Super_admin bootstrap — used by `seed_admin` (make createsuperuser / bootstrap)
DJANGO_SUPERUSER_PASSWORD=change-me-admin

# --- Production profile (deploy/docker-compose.prod.yml / `make prod-up`) ---
# Switch DJANGO_SETTINGS_MODULE=config.settings.prod (the override sets it per-service).
# ALLOWED_HOSTS MUST keep 127.0.0.1 (the internal container healthcheck sends Host:
# 127.0.0.1, and DEBUG=False rejects unlisted hosts with 400 → web never healthy).
# ALLOWED_HOSTS=127.0.0.1,localhost,sport-diagnostika.uz
# D3 is HTTP-only; the prod override sets SECURE_SSL_REDIRECT=False. D5 (TLS) drops that.
# SECURE_SSL_REDIRECT=True
# CSRF_TRUSTED_ORIGINS=https://sport-diagnostika.uz
