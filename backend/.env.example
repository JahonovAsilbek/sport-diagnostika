# Sample environment for the backend. Copy to `backend/.env` and adjust.
# `.env` is git-ignored; this template is committed.

# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database (PostgreSQL, psycopg v3)
DATABASE_URL=postgres://sport:sport@localhost:5432/sport
# docker compose `db` service credentials (keep in sync with DATABASE_URL)
POSTGRES_DB=sport
POSTGRES_USER=sport
POSTGRES_PASSWORD=sport

# Redis — cache + Celery broker/result backend
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS — SPA dev origin (Vite)
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Super_admin bootstrap — used by `seed_admin` (make createsuperuser / bootstrap)
DJANGO_SUPERUSER_PASSWORD=change-me-admin

# --- Production profile (deploy/docker-compose.prod.yml [+ .tls.yml]; see docs/DEPLOY.md) ---
# DJANGO_SETTINGS_MODULE=config.settings.prod is set per-service by the compose overlays.
# ALLOWED_HOSTS MUST keep 127.0.0.1 (the internal container healthcheck sends Host:
# 127.0.0.1, and DEBUG=False rejects unlisted hosts with 400 → web never healthy). Include www.
# ALLOWED_HOSTS=127.0.0.1,localhost,sport-diagnostika.uz,www.sport-diagnostika.uz
# CSRF_TRUSTED_ORIGINS=https://sport-diagnostika.uz,https://www.sport-diagnostika.uz
# SECURE_SSL_REDIRECT: the prod overlay sets "False" (HTTP-only); the tls.yml overlay sets
# "True". Only override here to force it.
#
# Gunicorn workers — deploy/gunicorn.conf.py defaults to (2 * cores) + 1; pin it if you want a
# fixed count (e.g. a shared VPS). Honored natively by gunicorn.
# WEB_CONCURRENCY=5
#
# --- TLS bootstrap (scripts/init-letsencrypt.sh) — shell-only, NOT read by Django ---
# Pass on the init invocation, e.g.:
#   DOMAIN=sport-diagnostika.uz LETSENCRYPT_EMAIL=admin@sport-diagnostika.uz STAGING=1 ./scripts/init-letsencrypt.sh
# STAGING=1 → Let's Encrypt staging (validate first, no rate limits); STAGING=0 → trusted cert.
#
# MIGRATE_ON_START is set to 0 for prod web by the compose overlay (scripts/deploy.sh runs the
# one-shot migrate). Leave it unset locally (defaults to 1 → web self-migrates in dev).

# --- Monitoring & logging (D7 / DVPS-18/19; see docs/MONITORING.md) ---
# Django log level. prod emits JSON; DEBUG floods — keep INFO/WARNING in prod.
LOG_LEVEL=INFO
# Error tracking (Sentry). Empty DSN = disabled (init is a no-op). Set on the server only.
# SENTRY_DSN=
# SENTRY_ENVIRONMENT=production
# SENTRY_RELEASE=            # set to the git SHA in scripts/deploy.sh to group events per deploy
# SENTRY_TRACES_SAMPLE_RATE=0.0
# Beat liveness — a heartbeat task pings this dead-man switch every 5 min (empty = disabled).
# HEALTHCHECK_PING_URL=https://hc-ping.com/<uuid>
# Disk-space alert (scripts/disk-alert.sh, run via cron) + Telegram alert routing (opt-in).
# DISK_ALERT_THRESHOLD=85
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
